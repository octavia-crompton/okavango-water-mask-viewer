# .streamlit/secrets.toml
# Copy this file to .streamlit/secrets.toml and fill in your values.
# NEVER commit secrets.toml to git — it is already in .gitignore.

# Paste the full contents of your GEE service account JSON key here as a string.
# Get it from: GCP Console → IAM → Service Accounts → Keys → Add Key → JSON
gee_service_account_json = '''
{
  "type": "service_account",
  "project_id": "ee-okavango",
  "private_key_id": "...",
  "private_key": "-----BEGIN RSA PRIVATE KEY-----\n...",
  "client_email": "my-sa@ee-okavango.iam.gserviceaccount.com",
  "client_id": "...",
  "auth_uri": "https://accounts.google.com/o/oauth2/auth",
  "token_uri": "https://oauth2.googleapis.com/token"
}
'''
